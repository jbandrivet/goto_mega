void cmd_goto(double ra_h, double dec_d){
    targetRA = ra_h;
    targetDEC = dec_d;
    if (currentCat == CAT_SYSSOL && !selectedIsStar) {
        if (selectedObj.id == 0) mega_cmd(":TS#");
        else if (selectedObj.id == 1) mega_cmd(":TL#");
        else mega_cmd(":TQ#");
    } else {
        mega_cmd(":TQ#");
    }
    mega_cmd(":Sr"+formatRA(ra_h));
    mega_cmd(":Sd"+formatDEC(dec_d));
    String resp=mega_cmd(":MS");
    if(resp.startsWith("0")){
        uiState=UI_SLEWING;
    } else {
        char buf[21]; snprintf(buf,21,"%-20s",resp.c_str());
        showMessage("  !! IMPOSSIBLE !!  ", buf, 2500, UI_OBJECT_INFO);
    }
    lcdNeedsRefresh=true;
}

void cmd_stop()           { mega_cmd(":Q",false); m_isTracking=false; m_isSlewing=false; }
void cmd_toggleTracking() {
    if(m_isTracking) mega_cmd(":Td",false);
    else             mega_cmd(":Te",false);
}

void cmd_setSpeed(double s){
    int nnn = (int)(s*10);
    if(nnn < 5)  nnn = 5;
    if(nnn > 40) nnn = 40;
    String c = ":BV "; c += String(nnn);
    mega_cmd(c);
    m_slewSpeed = nnn / 10.0;
}

void cmd_parking()         { mega_cmd(":hP"); }
