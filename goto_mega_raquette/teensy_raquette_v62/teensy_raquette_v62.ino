const char* const OBJ_TYPE_NAMES[] = {
    typeGal, typeOC, typeGC, typeNeb, typePN, typeSN, typeDS, typeAst, typeStar
};

const char* getTypeName(uint8_t type) {
    if (type >= 9) type = 0;
    if (isEnglish) {
        const char* const OBJ_TYPE_NAMES_EN[] = {
            "Galaxy      ", "Open Cluster", "Glob.Cluster", "Nebula      ", "Plan.Nebula ", "Supernova R.", "Double Star ", "Asterism    ", "Star        "
        };
        return OBJ_TYPE_NAMES_EN[type];
    }
    return OBJ_TYPE_NAMES[type];
}

