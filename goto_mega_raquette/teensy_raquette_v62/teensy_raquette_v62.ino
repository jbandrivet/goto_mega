uint32_t getCatalogCount(CatID c){
    switch(c){
        case CAT_MESSIER:  return MESSIER_COUNT;
        case CAT_NGC:      return NGC_COUNT;
        case CAT_IC:       return IC_COUNT;
        case CAT_PK:       return PK_COUNT;
        case CAT_CALDWELL: return CALDWELL_COUNT;
        case CAT_BSC:      return BSC_COUNT;
        case CAT_SYSSOL:
            if(!timeFetched) { syncDataFromMega(); timeFetched = true; }
            computeSysSol(dt_y, dt_m, dt_d, dt_hr, dt_min, dt_sec);
            return SYSSOL_COUNT;
        default: return 0;
    }
}

bool getObj(CatID c, uint32_t i, DeepSkyObject &out){
    if(c==CAT_BSC) return false;
    switch(c){
        case CAT_MESSIER:  out=getObjectFromCatalog(catalogM,        i); return true;
        case CAT_NGC:      out=getObjectFromCatalog(catalogNGC,      i); return true;
        case CAT_IC:       out=getObjectFromCatalog(catalogIC,       i); return true;
        case CAT_PK:       out=getObjectFromCatalog(catalogPK,       i); return true;
        case CAT_CALDWELL: out=getObjectFromCatalog(catalogCaldwell, i); return true;
        default: return false;
    }
}

const char* getCatPrefix(CatID c){
    switch(c){
        case CAT_MESSIER:  return "M";
        case CAT_NGC:      return "NGC";
        case CAT_IC:       return "IC";
        case CAT_PK:       return "PK";
        case CAT_CALDWELL: return "C";
        case CAT_BSC:      return "*";
        default: return "?";
    }
}

void selectCurrentObject(){
    if(currentCat == CAT_SYSSOL) {
        selectedIsStar = false;
        selectedObj.id = objectIndex;
        selectedObj.ra = sysSolObjs[objectIndex].ra;
        selectedObj.dec = sysSolObjs[objectIndex].dec;
        selectedObj.mag = 0;
        selectedObj.type = 255;
        return;
    }
    if(currentCat==CAT_BSC){
        selectedStar=getStarFromCatalog(objectIndex);
        selectedIsStar=true;
    } else {
        getObj(currentCat,objectIndex,selectedObj);
        selectedIsStar=false;
    }
}

