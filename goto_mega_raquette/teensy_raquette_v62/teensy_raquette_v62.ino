void sendLocationToMega() {
    char buf[16];
    int lat_deg = abs(obs_lat);
    int lat_min = (abs(obs_lat) - lat_deg) * 60;
    snprintf(buf, 16, ":St%c%02d*%02d", obs_lat>=0?'+':'-', lat_deg, lat_min);
    mega_cmd(buf);
    int lon_deg = abs(obs_lon);
    int lon_min = (abs(obs_lon) - lon_deg) * 60;
    snprintf(buf, 16, ":Sg%c%03d*%02d", obs_lon>=0?'+':'-', lon_deg, lon_min);
    mega_cmd(buf);
}

