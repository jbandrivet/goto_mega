// ============================================================
// SECTION 7 : COMMUNICATION
// ============================================================
String mega_cmd(const String &cmd, bool needsReply=true){
    while(Serial1.available()) Serial1.read(); // Flush out-of-sync data
    Serial1.print(cmd);
    Serial1.print('#');
    if(!needsReply) return "";
    String resp="";
    unsigned long t0=millis();
    while(millis()-t0 < TEENSY_TIMEOUT_MS){
        while(Serial1.available()){
            char c=(char)Serial1.read();
            if(c=='#') return resp;
            resp+=c;
            if (cmd.startsWith(":S") && !cmd.startsWith(":SC") && !cmd.startsWith(":SL") && !cmd.startsWith(":SG") && resp.length() == 1) {
                if (resp[0] == '0' || resp[0] == '1') return resp;
            }
            if (cmd == ":MS" && resp == "0") return resp;
            if (cmd == ":Q" && resp == "0") return resp;
        }
    }
    return resp; // Return whatever we received instead of ""!
}

String formatRA(double ra_h){
    char b[10];
    int h=(int)ra_h, m=(int)((ra_h-h)*60.0), s=(int)(((ra_h-h)*60.0-m)*60.0);
    sprintf(b,"%02d:%02d:%02d",h,m,s);
    return String(b);
}
String formatDEC(double dec_d){
    char b[12];
    bool neg=(dec_d<0); dec_d=fabs(dec_d);
    int d=(int)dec_d, m=(int)((dec_d-d)*60.0), s=(int)(((dec_d-d)*60.0-m)*60.0);
    sprintf(b,"%c%02d*%02d:%02d",neg?'-':'+',d,m,s);
    return String(b);
}
double parseRA(const String &s){
    if(s.length()<8) return 0.0;
    return s.substring(0,2).toInt()+s.substring(3,5).toInt()/60.0
          +s.substring(6,8).toInt()/3600.0;
}
double parseDEC_r(const String &s){
    if(s.length()<5) return 0.0;
    bool neg=(s.charAt(0)=='-');
    String t=s.substring(1); t.replace('*',':'); t.replace('\'',':');
    double v=t.substring(0,2).toInt()+t.substring(3,5).toInt()/60.0;
    if(t.length()>=8) v+=t.substring(6,8).toInt()/3600.0;
    return neg?-v:v;
}

void pollMega(){
    String resp=mega_cmd(":GBE");
    if(resp.length()<5){ m_online=false; return; }
    m_online=true;
    int idx=0;
    auto next=[&]()->String{
        int c=resp.indexOf(',',idx);
        String v=(c<0)?resp.substring(idx):resp.substring(idx,c);
        idx=(c<0)?(int)resp.length():c+1;
        return v;
    };
    m_isTracking=next().toInt();
    m_isSlewing =next().toInt();
    if (m_isSlewing) {
        String tra = mega_cmd(":Gr");
        String tdec = mega_cmd(":Gd");
        if (tra.length() >= 8) targetRA = parseRA(tra);
        if (tdec.length() >= 5) targetDEC = parseDEC_r(tdec);
    }
    m_limitHit  =next().toInt();
    m_slewSpeed =next().toInt()/10.0;
    m_currentAlt=next().toFloat();
    m_currentAz =next().toFloat();
    m_isParked  =next().toInt();
    m_isAligned =next().toInt();

    String gu = mega_cmd(":GU");
    if(gu.length() > 0) {
        m_timeSet = (gu.indexOf('F') < 0);
    }

    String ra=mega_cmd(":GR"), dec=mega_cmd(":GD");
    if(ra.length() >=8) m_currentRA =parseRA(ra);
    if(dec.length()>=5) m_currentDEC=parseDEC_r(dec);
    
    String gm = mega_cmd(":GM");
    global_gm = gm;
    if (gm.startsWith("AltAz")) mountType = 0;
    else if (gm.startsWith("ForkEq")) mountType = 1;
    else if (gm.startsWith("GermanEq")) mountType = 2;
}

